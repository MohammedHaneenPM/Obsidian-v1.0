{
  "sections": {
    "main": {
      "type": "main-product",
      "blocks": {
        "vendor": {
          "type": "text",
          "settings": {
            "text": "{{ product.vendor }}",
            "text_style": "uppercase"
          }
        },
        "title": {
          "type": "title"
        },
        "price": {
          "type": "price"
        },
        "variant_picker": {
          "type": "variant_picker",
          "settings": {
            "picker_type": "button",
            "swatch_shape": "circle"
          }
        },
        "quantity_selector": {
          "type": "quantity_selector"
        },
        "buy_buttons": {
          "type": "buy_buttons",
          "settings": {
            "show_dynamic_checkout": true,
            "show_gift_card_recipient": true
          }
        },
        "description": {
          "type": "description"
        },
        "shipping_tab": {
          "type": "collapsible_tab",
          "settings": {
            "heading": "Shipping & returns",
            "icon": "truck",
            "content": "<p>Add your shipping and returns policy details here.</p>"
          }
        },
        "care_tab": {
          "type": "collapsible_tab",
          "settings": {
            "heading": "Materials & care",
            "icon": "iron",
            "content": "<p>Add material composition and care instructions here.</p>"
          }
        },
        "share": {
          "type": "share",
          "settings": {
            "share_label": "Share"
          }
        }
      },
      "block_order": [
        "vendor",
        "title",
        "price",
        "variant_picker",
        "quantity_selector",
        "buy_buttons",
        "description",
        "shipping_tab",
        "care_tab",
        "share"
      ],
      "settings": {
        "enable_sticky_info": true,
        "color_scheme": "scheme-1",
        "media_position": "left",
        "gallery_layout": "stacked",
        "media_size": "large",
        "constrain_to_viewport": true,
        "media_fit": "contain",
        "image_zoom": "lightbox",
        "mobile_thumbnails": "hide",
        "hide_variants": true,
        "enable_video_looping": false,
        "padding_top": 36,
        "padding_bottom": 12
      }
    },
    "disclosures": {
      "type": "disclosures",
      "settings": {
        "padding_top": 36,
        "padding_bottom": 0
      }
    },
    "related-products": {
      "type": "related-products",
      "settings": {
        "heading": "You may also like",
        "heading_size": "h2",
        "products_to_show": 4,
        "columns_desktop": 4,
        "color_scheme": "scheme-1",
        "image_ratio": "square",
        "image_shape": "default",
        "show_secondary_image": true,
        "show_vendor": false,
        "show_rating": false,
        "columns_mobile": "2",
        "padding_top": 36,
        "padding_bottom": 28
      }
    },
    "premium-merchandising": {
      "type": "premium-merchandising",
      "blocks": {
        "product_info": {
          "type": "product_info"
        },
        "inventory": {
          "type": "inventory_urgency_premium"
        },
        "shipping": {
          "type": "shipping_estimate_premium"
        },
        "free_shipping": {
          "type": "free_shipping_premium"
        },
        "returns": {
          "type": "return_policy_premium"
        },
        "secure": {
          "type": "secure_checkout_premium"
        }
      },
      "block_order": [
        "product_info",
        "inventory",
        "shipping",
        "free_shipping",
        "returns",
        "secure"
      ],
      "settings": {
        "padding_top": 36,
        "padding_bottom": 36
      }
    },
    "product-accordion-primary": {
      "type": "product-accordion-primary",
      "blocks": {
        "specifications": {
          "type": "product_specifications"
        }
      },
      "block_order": [
        "specifications"
      ],
      "settings": {
        "padding_top": 36,
        "padding_bottom": 36
      }
    },
    "product-accordion-secondary": {
      "type": "product-accordion-secondary",
      "blocks": {
        "downloads": {
          "type": "product_downloads"
        }
      },
      "block_order": [
        "downloads"
      ],
      "settings": {
        "padding_top": 36,
        "padding_bottom": 36
      }
    },
    "sticky-add-to-cart": {
      "type": "sticky-add-to-cart-premium",
      "settings": {
        "enable_desktop": true,
        "enable_mobile": true,
        "show_image": true,
        "show_variant_title": true,
        "show_quantity": true,
        "show_dynamic_checkout": false,
        "color_scheme": "scheme-1"
      }
    }
  },
  "order": [
    "main",
    "premium-merchandising",
    "product-accordion-primary",
    "product-accordion-secondary",
    "disclosures",
    "related-products",
    "sticky-add-to-cart"
  ]
}
