{% comment %}
  Renders a merchant-set (not product-metafield) star rating, e.g. for a
  testimonial/review block. Visually reuses the theme's existing
  `.rating-star` CSS technique (assets/component-rating.css / Dawn's
  product rating), so no new star-drawing CSS is introduced - only a
  small wrapper rule in the new section stylesheet that calls this.

  Accepts:
  - rating: {Number} 0-5, supports .5 steps (required)
  - max: {Number} Defaults to 5 (optional)

  Usage:
  {% render 'star-rating', rating: block.settings.rating %}
{% endcomment %}
{%- liquid
  assign max = max | default: 5
  assign rating = rating | default: 5
  assign rating_decimal = 0
  assign full = rating | floor
  assign remainder = rating | minus: full
  if remainder >= 0.25 and remainder < 0.75
    assign rating_decimal = 0.5
  elsif remainder >= 0.75
    assign rating_decimal = 1
  endif
-%}
<div
  class="star-rating-premium"
  role="img"
  aria-label="{{ 'accessibility.star_reviews_info' | t: rating_value: rating, rating_max: max }}"
  style="--rating: {{ full }}; --rating-max: {{ max }}; --rating-decimal: {{ rating_decimal }};"
>
  <span class="star-rating-premium__stars rating-star" aria-hidden="true"></span>
</div>
