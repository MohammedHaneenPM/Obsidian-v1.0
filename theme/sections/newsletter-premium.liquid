{% comment %}
  Newsletter Premium - Milestone 4, Phase 3.

  A new, standalone email-capture section, distinct from the existing
  sections/newsletter.liquid (untouched, block-based, still available) and
  sections/email-signup-banner.liquid (untouched). This version adds an
  optional side image, a background image OR background video, a privacy
  notice line, and a merchant-configurable success message - none of which
  the two existing sections support. Reuses the same Shopify 'customer'
  form pattern as sections/newsletter.liquid for consistency and
  reliability, rather than inventing a new form mechanism.
{% endcomment %}

{{ 'component-newsletter.css' | asset_url | stylesheet_tag }}
{{ 'component-newsletter-premium.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

{%- liquid
  assign has_media = false
  if section.settings.background_image != blank or section.settings.background_video != blank
    assign has_media = true
  endif
  assign background_video_source = section.settings.background_video.sources | last
-%}

<div class="color-{{ section.settings.color_scheme }} gradient">
  <div
    class="
      newsletter-premium
      newsletter-premium--{{ section.settings.layout }}
      section-{{ section.id }}-padding
    "
  >
    {%- if section.settings.layout == 'background' and has_media -%}
      <div class="newsletter-premium__background" aria-hidden="true">
        {%- if section.settings.background_video != blank -%}
          <video
            class="newsletter-premium__background-video"
            autoplay
            muted
            loop
            playsinline
            preload="none"
            {% if section.settings.background_image != blank %}
              poster="{{ section.settings.background_image | image_url: width: 1920 }}"
            {% endif %}
          >
            <source src="{{ background_video_source.url }}" type="{{ background_video_source.mime_type }}">
          </video>
        {%- elsif section.settings.background_image != blank -%}
          <img
            src="{{ section.settings.background_image | image_url: width: 1920 }}"
            srcset="{{ section.settings.background_image | image_url: width: 750 }} 750w, {{ section.settings.background_image | image_url: width: 1500 }} 1500w, {{ section.settings.background_image | image_url: width: 1920 }} 1920w"
            sizes="100vw"
            alt=""
            width="{{ section.settings.background_image.width }}"
            height="{{ section.settings.background_image.height }}"
            loading="lazy"
          >
        {%- endif -%}
        <div class="newsletter-premium__overlay"></div>
      </div>
    {%- endif -%}

    <div class="newsletter-premium__inner page-width">
      {%- if section.settings.layout == 'split' and section.settings.image != blank -%}
        <div class="newsletter-premium__media media">
          <img
            src="{{ section.settings.image | image_url: width: 900 }}"
            srcset="{{ section.settings.image | image_url: width: 450 }} 450w, {{ section.settings.image | image_url: width: 900 }} 900w"
            sizes="(min-width: 750px) 50vw, 100vw"
            alt="{{ section.settings.image.alt | escape }}"
            width="{{ section.settings.image.width }}"
            height="{{ section.settings.image.height }}"
            loading="lazy"
          >
        </div>
      {%- endif -%}

      <div class="newsletter-premium__content">
        {%- if section.settings.eyebrow != blank -%}
          <p class="newsletter-premium__eyebrow caption-with-letter-spacing">{{ section.settings.eyebrow | escape }}</p>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 class="newsletter-premium__heading inline-richtext h1">{{ section.settings.heading }}</h2>
        {%- endif -%}
        {%- if section.settings.description != blank -%}
          <div class="newsletter-premium__description rte">{{ section.settings.description }}</div>
        {%- endif -%}

        {% form 'customer', class: 'newsletter-premium-form newsletter-form' %}
          <input type="hidden" name="contact[tags]" value="newsletter">
          <div class="newsletter-premium-form__field-wrapper newsletter-form__field-wrapper">
            <div class="field">
              <input
                id="NewsletterPremiumForm--{{ section.id }}"
                type="email"
                name="contact[email]"
                class="field__input"
                value="{{ form.email }}"
                aria-required="true"
                autocorrect="off"
                autocapitalize="off"
                autocomplete="email"
                {% if form.errors %}
                  autofocus
                  aria-invalid="true"
                  aria-describedby="NewsletterPremium-error--{{ section.id }}"
                {% elsif form.posted_successfully? %}
                  aria-describedby="NewsletterPremium-success--{{ section.id }}"
                {% endif %}
                placeholder="{{ 'newsletter.label' | t }}"
                required
              >
              <label class="field__label" for="NewsletterPremiumForm--{{ section.id }}">
                {{ 'newsletter.label' | t }}
              </label>
              <button
                type="submit"
                class="newsletter-form__button field__button"
                name="commit"
                id="SubscribePremium-{{ section.id }}"
                aria-label="{{ 'newsletter.button_label' | t }}"
              >
                <span class="svg-wrapper">{{- 'icon-arrow.svg' | inline_asset_content -}}</span>
              </button>
            </div>
            {%- if form.errors -%}
              <small class="newsletter-form__message form__message" id="NewsletterPremium-error--{{ section.id }}">
                <span class="svg-wrapper">{{- 'icon-error.svg' | inline_asset_content -}}</span>
                {{- form.errors.translated_fields.email | capitalize }}
                {{ form.errors.messages.email -}}
              </small>
            {%- endif -%}
          </div>

          {%- if section.settings.privacy_notice != blank -%}
            <p class="newsletter-premium-form__privacy">{{ section.settings.privacy_notice }}</p>
          {%- endif -%}

          {%- if form.posted_successfully? -%}
            <h3
              class="newsletter-form__message newsletter-form__message--success form__message"
              id="NewsletterPremium-success--{{ section.id }}"
              tabindex="-1"
              autofocus
            >
              <span class="svg-wrapper">{{- 'icon-success.svg' | inline_asset_content -}}</span>
              {%- if section.settings.success_message != blank -%}
                {{- section.settings.success_message | escape -}}
              {%- else -%}
                {{- 'newsletter.success' | t -}}
              {%- endif -%}
            </h3>
          {%- endif -%}
        {% endform %}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Newsletter (premium)",
  "class": "section-newsletter-premium",
  "tag": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "select",
      "id": "layout",
      "label": "Layout",
      "options": [
        { "value": "centered", "label": "Grid" },
        { "value": "split", "label": "Carousel" },
        { "value": "background", "label": "Marquee" }
      ],
      "default": "centered"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Join our newsletter"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>Be the first to know about new arrivals, sales, and more.</p>"
    },
    {
      "type": "text",
      "id": "privacy_notice",
      "label": "Privacy notice",
      "default": "By subscribing you agree to our Privacy Policy."
    },
    {
      "type": "text",
      "id": "success_message",
      "label": "Success message",
      "info": "Shown after a successful signup. Leave blank to use the default message."
    },
    {
      "type": "header",
      "content": "Media"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image",
      "info": "Used in the split layout, next to the form."
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image",
      "info": "Used in the background layout. Also used as the video poster if a background video is set."
    },
    {
      "type": "video",
      "id": "background_video",
      "label": "Background video",
      "info": "Optional. Overrides the background image when set. Muted, looped, autoplaying."
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-2"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 52
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 52
    }
  ],
  "presets": [
    {
      "name": "Newsletter (premium)"
    }
  ]
}
{% endschema %}
