{% comment %}
  Upsell Products - Milestone 5, Phase 2.
  Manual product selection is the real, working path. "Automatic
  recommendation" is explicitly a placeholder per the brief - rather than
  faking a recommendation algorithm, this shows a clear, honest message
  when no manual products are configured. Bundle integration: optionally
  renders as a selectable list with a running total and one add-to-cart
  action, reusing the exact same bundle-item-premium snippet and JS class
  Frequently Bought Together and Product Bundles use (registered under a
  third tag name, zero duplication).
{% endcomment %}

{{ 'component-card-premium.css' | asset_url | stylesheet_tag }}
{{ 'component-slider.css' | asset_url | stylesheet_tag }}
{{ 'component-price.css' | asset_url | stylesheet_tag }}
{{ 'component-bundle-item-premium.css' | asset_url | stylesheet_tag }}
{{ 'component-frequently-bought-together-premium.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

{%- liquid
  assign is_carousel = false
  if section.settings.layout == 'carousel'
    assign is_carousel = true
  endif
  assign has_products = false
  if section.blocks.size > 0
    assign has_products = true
  endif
-%}

<div class="color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding">
  <div class="page-width">
    {%- render 'section-header',
      heading: section.settings.heading,
      description: section.settings.description,
      alignment: 'left',
      section_id: section.id
    -%}

    {%- if has_products and section.settings.bundle_style -%}
      <upsell-premium
        class="fbt-premium"
        data-money-format="{{ shop.money_format | escape }}"
        data-discount-percent="0"
        data-select-at-least-one-text="{{ 'general.fbt.select_at_least_one' | t }}"
        data-added-text="{{ 'general.fbt.added' | t }}"
      >
        <ul class="fbt-premium__list" role="list">
          {%- for block in section.blocks -%}
            {%- if block.settings.product != blank -%}
              <div {{ block.shopify_attributes }}>
                {%- render 'bundle-item-premium', bundle_product: block.settings.product, required: false, checked: false, input_name: 'upsell-' | append: forloop.index -%}
              </div>
            {%- endif -%}
          {%- endfor -%}
        </ul>
        <div class="fbt-premium__summary">
          <p class="fbt-premium__total">
            <span>{{ 'general.fbt.total_price' | t }}</span>
            <span data-bundle-total>{{ 0 | money }}</span>
          </p>
          <button type="button" class="button button--primary fbt-premium__add-all" data-bundle-add-all>
            <span>{{ 'general.fbt.add_all_to_cart' | t }}</span>
            <div class="loading__spinner hidden">
              <svg aria-hidden="true" focusable="false" class="spinner" viewBox="0 0 66 66" xmlns="http://www.w3.org/2000/svg">
                <circle class="path" fill="none" stroke-width="6" cx="33" cy="33" r="30"></circle>
              </svg>
            </div>
          </button>
          <p class="fbt-premium__status visually-hidden" role="status" data-bundle-status></p>
        </div>
      </upsell-premium>
      <script src="{{ 'product-merchandising.js' | asset_url }}" defer="defer"></script>
    {%- elsif has_products -%}
      {%- capture upsell_items -%}
        {%- for block in section.blocks -%}
          {%- if block.settings.product != blank -%}
            <li
              id="Slide-{{ section.id }}-{{ forloop.index }}"
              class="upsell-premium__item grid__item{% if is_carousel %} slider__slide{% endif %}"
              {{ block.shopify_attributes }}
            >
              {%- render 'product-card-premium',
                card_product: block.settings.product,
                media_aspect_ratio: 'square',
                show_quick_add: true,
                section_id: section.id
              -%}
            </li>
          {%- endif -%}
        {%- endfor -%}
      {%- endcapture -%}
      {%- render 'premium-grid',
        items: upsell_items,
        is_carousel: is_carousel,
        columns_desktop: section.settings.columns_desktop,
        columns_mobile: section.settings.columns_mobile,
        total_count: section.blocks.size,
        section_id: section.id,
        grid_class: 'upsell-premium__grid'
      -%}
    {%- elsif request.design_mode -%}
      <p class="premium-section-empty-state">{{ 'general.upsell.automatic_placeholder' | t }}</p>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Upsell products",
  "class": "section-upsell-premium",
  "tag": "section",
  "max_blocks": 6,
  "settings": [
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Upgrade your order"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description"
    },
    {
      "type": "paragraph",
      "content": "Automatic upsell recommendations are a placeholder in this phase - add products manually below for a working upsell."
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "checkbox",
      "id": "bundle_style",
      "label": "Show as a selectable list with a running total",
      "info": "Reuses the same interaction as Product Bundles: checkboxes, a running total, and one \"add to cart\" button, instead of a plain product grid.",
      "default": false
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Grid layout",
      "options": [
        { "value": "grid", "label": "Grid" },
        { "value": "carousel", "label": "Carousel" }
      ],
      "default": "grid",
      "info": "Only used when \"selectable list\" above is off."
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "Columns on desktop",
      "min": 2,
      "max": 5,
      "step": 1,
      "default": 3
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "label": "Columns on mobile",
      "options": [
        { "value": "1", "label": "1" },
        { "value": "2", "label": "2" }
      ],
      "default": "2"
    },
    {
      "type": "header",
      "content": "t:sections.all.colors.label"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Product",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Upsell products"
    }
  ]
}
{% endschema %}
