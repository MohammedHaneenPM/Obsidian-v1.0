{% comment %}
  Cross-sell Products - Milestone 5, Phase 2.
  Can be placed on any template. On collection/product-based source, pulls
  real products (not recommendations); on manual, uses blocks.
{% endcomment %}

{{ 'component-card-premium.css' | asset_url | stylesheet_tag }}
{{ 'component-slider.css' | asset_url | stylesheet_tag }}
{{ 'component-price.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

{%- liquid
  assign is_carousel = false
  if section.settings.layout == 'carousel'
    assign is_carousel = true
  endif

  case section.settings.source
    when 'collection'
      assign cross_sell_products = section.settings.collection.products
    when 'product'
      assign cross_sell_products = section.settings.reference_product.collections.first.products
    else
      assign cross_sell_products = blank
  endcase
-%}

<div class="color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding">
  <div class="page-width">
    {%- render 'section-header',
      heading: section.settings.heading,
      description: section.settings.description,
      alignment: 'left',
      section_id: section.id
    -%}

    {%- if cross_sell_products.size > 0 -%}
      {%- capture cross_sell_items -%}
        {%- for cross_sell_product in cross_sell_products limit: section.settings.products_to_show -%}
          <li id="Slide-{{ section.id }}-{{ forloop.index }}" class="cross-sell-premium__item grid__item{% if is_carousel %} slider__slide{% endif %}">
            {%- render 'product-card-premium',
              card_product: cross_sell_product,
              media_aspect_ratio: 'square',
              show_quick_add: true,
              section_id: section.id
            -%}
          </li>
        {%- endfor -%}
      {%- endcapture -%}
      {%- render 'premium-grid',
        items: cross_sell_items,
        is_carousel: is_carousel,
        columns_desktop: section.settings.columns_desktop,
        columns_mobile: section.settings.columns_mobile,
        total_count: cross_sell_products.size | at_most: section.settings.products_to_show,
        section_id: section.id,
        grid_class: 'cross-sell-premium__grid'
      -%}
    {%- elsif section.blocks.size > 0 -%}
      {%- capture cross_sell_items -%}
        {%- for block in section.blocks -%}
          {%- if block.settings.product != blank -%}
            <li
              id="Slide-{{ section.id }}-{{ forloop.index }}"
              class="cross-sell-premium__item grid__item{% if is_carousel %} slider__slide{% endif %}"
              {{ block.shopify_attributes }}
            >
              {%- render 'product-card-premium',
                card_product: block.settings.product,
                media_aspect_ratio: 'square',
                show_quick_add: true,
                section_id: section.id
              -%}
            </li>
          {%- endif -%}
        {%- endfor -%}
      {%- endcapture -%}
      {%- render 'premium-grid',
        items: cross_sell_items,
        is_carousel: is_carousel,
        columns_desktop: section.settings.columns_desktop,
        columns_mobile: section.settings.columns_mobile,
        total_count: section.blocks.size,
        section_id: section.id,
        grid_class: 'cross-sell-premium__grid'
      -%}
    {%- elsif request.design_mode -%}
      <p class="premium-section-empty-state">{{ 'general.onboarding.add_cross_sell_products' | t }}</p>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Cross-sell products",
  "class": "section-cross-sell-premium",
  "tag": "section",
  "max_blocks": 12,
  "settings": [
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Complete the look"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description"
    },
    {
      "type": "header",
      "content": "Products"
    },
    {
      "type": "select",
      "id": "source",
      "label": "Source",
      "options": [
        { "value": "manual", "label": "Manual selection (blocks)" },
        { "value": "collection", "label": "Collection" },
        { "value": "product", "label": "Another product's collection" }
      ],
      "default": "manual",
      "info": "\"Another product's collection\" shows other products from the first collection a chosen reference product belongs to - a simple, real proxy for \"products like this\" without needing a recommendation engine."
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection",
      "info": "Used when source is Collection."
    },
    {
      "type": "product",
      "id": "reference_product",
      "label": "Reference product",
      "info": "Used when source is \"Another product's collection\"."
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "Products to show",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 4
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Layout",
      "options": [
        { "value": "grid", "label": "Grid" },
        { "value": "carousel", "label": "Carousel" }
      ],
      "default": "grid"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "Columns on desktop",
      "min": 2,
      "max": 5,
      "step": 1,
      "default": 4
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "label": "Columns on mobile",
      "options": [
        { "value": "1", "label": "1" },
        { "value": "2", "label": "2" }
      ],
      "default": "2"
    },
    {
      "type": "header",
      "content": "t:sections.all.colors.label"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Product",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Cross-sell products"
    }
  ]
}
{% endschema %}
