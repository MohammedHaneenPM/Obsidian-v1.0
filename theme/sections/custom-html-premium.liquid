{% comment %}
  Custom HTML - Milestone 4, Phase 4.

  A merchant-editable HTML/Liquid escape hatch, distinct from the theme's
  existing sections/custom-liquid.liquid (untouched - that one is a bare
  passthrough with no layout controls). This version adds a CSS class
  field, a width constraint, a color scheme, and independent padding/margin
  controls, with an optional page-width wrapper.
{% endcomment %}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    margin-top: {{ section.settings.margin_top | times: 0.75 | round: 0 }}px;
    margin-bottom: {{ section.settings.margin_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
      margin-top: {{ section.settings.margin_top }}px;
      margin-bottom: {{ section.settings.margin_bottom }}px;
    }
  }

  .section-{{ section.id }}-width {
    max-width: {{ section.settings.max_width }}px;
    margin-left: auto;
    margin-right: auto;
  }
{%- endstyle -%}

<div class="color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding custom-html-premium {{ section.settings.css_class }}">
  {%- if section.settings.width == 'page-width' -%}
    <div class="page-width">
      {{ section.settings.html }}
    </div>
  {%- elsif section.settings.width == 'constrained' -%}
    <div class="page-width">
      <div class="section-{{ section.id }}-width">
        {{ section.settings.html }}
      </div>
    </div>
  {%- else -%}
    {{ section.settings.html }}
  {%- endif -%}
</div>

{% schema %}
{
  "name": "Custom HTML",
  "class": "section-custom-html-premium",
  "tag": "section",
  "settings": [
    {
      "type": "liquid",
      "id": "html",
      "label": "HTML / Liquid",
      "info": "Supports Liquid. Use responsibly - invalid markup can affect the rest of the page."
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "width",
      "label": "Width",
      "options": [
        { "value": "full", "label": "Full width (edge to edge)" },
        { "value": "page-width", "label": "Page width" },
        { "value": "constrained", "label": "Constrained" }
      ],
      "default": "page-width"
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Maximum width",
      "info": "Used when width is set to \"Constrained\".",
      "min": 400,
      "max": 1200,
      "step": 20,
      "unit": "px",
      "default": 800
    },
    {
      "type": "text",
      "id": "css_class",
      "label": "CSS class",
      "info": "Optional. Adds custom class name(s) to the section wrapper for targeted styling, e.g. from another Custom HTML section's embedded <style> tag."
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 0
    },
    {
      "type": "header",
      "content": "Margin"
    },
    {
      "type": "range",
      "id": "margin_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top margin",
      "default": 0
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom margin",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Custom HTML"
    }
  ]
}
{% endschema %}
