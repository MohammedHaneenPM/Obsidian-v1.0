{% comment %}
  Horizontal Gallery - Milestone 4, Phase 4.

  A native CSS scroll-snap horizontal gallery (no GSAP/ScrollTrigger -
  that's Milestone 8 scope). Each block/item can be "large" or "small"
  width, optionally link to a product, and show a caption. Prev/Next
  buttons just call scrollBy() - plain functionality, no animation.
{% endcomment %}

{{ 'component-horizontal-gallery-premium.css' | asset_url | stylesheet_tag }}
{{ 'component-premium-shared.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding">
  <div class="horizontal-gallery-premium-wrapper page-width">
    <div class="horizontal-gallery-premium__header">
      {%- render 'section-header',
        eyebrow: section.settings.eyebrow,
        heading: section.settings.heading,
        description: section.settings.description,
        alignment: 'left',
        section_id: section.id
      -%}

      {%- if section.settings.button_text != blank -%}
        <div class="horizontal-gallery-premium__cta">
          {%- render 'button', text: section.settings.button_text, url: section.settings.button_url, style: 'link' -%}
        </div>
      {%- endif -%}
    </div>

    {%- if section.blocks.size > 0 -%}
      <div class="horizontal-gallery-premium">
        <ul
          class="horizontal-gallery-premium__track horizontal-gallery-premium__track--{{ section.settings.layout }}"
          id="Horizontal-Gallery-{{ section.id }}"
          role="list"
        >
          {%- for block in section.blocks -%}
            {%- liquid
              assign item_product = block.settings.product
              assign item_url = block.settings.link
              if item_product != blank
                assign item_url = item_product.url
              endif
            -%}
            <li
              class="horizontal-gallery-premium__item horizontal-gallery-premium__item--{{ block.settings.size }}"
              {{ block.shopify_attributes }}
            >
              {%- if item_url != blank -%}<a href="{{ item_url }}" class="horizontal-gallery-premium__link">{%- endif -%}
                <div class="horizontal-gallery-premium__media">
                  {%- if block.settings.image != blank -%}
                    <img
                      src="{{ block.settings.image | image_url: width: 1200 }}"
                      srcset="
                        {{ block.settings.image | image_url: width: 400 }} 400w,
                        {{ block.settings.image | image_url: width: 700 }} 700w,
                        {{ block.settings.image | image_url: width: 1200 }} 1200w
                      "
                      sizes="{% if block.settings.size == 'large' %}(min-width: 750px) 44vw, 80vw{% else %}(min-width: 750px) 26vw, 60vw{% endif %}"
                      alt="{{ block.settings.image.alt | escape }}"
                      width="{{ block.settings.image.width }}"
                      height="{{ block.settings.image.height }}"
                      loading="lazy"
                    >
                  {%- else -%}
                    {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
                  {%- endif -%}
                </div>
                {%- if block.settings.caption != blank -%}
                  <p class="horizontal-gallery-premium__caption">{{ block.settings.caption | escape }}</p>
                {%- endif -%}
              {%- if item_url != blank -%}</a>{%- endif -%}
            </li>
          {%- endfor -%}
        </ul>

        <div class="horizontal-gallery-premium__nav">
          <button type="button" class="horizontal-gallery-premium__nav-button" data-horizontal-gallery-prev aria-label="{{ 'general.horizontal_gallery.previous' | t }}" aria-controls="Horizontal-Gallery-{{ section.id }}">
            <span class="svg-wrapper">{{- 'icon-caret.svg' | inline_asset_content -}}</span>
          </button>
          <button type="button" class="horizontal-gallery-premium__nav-button horizontal-gallery-premium__nav-button--next" data-horizontal-gallery-next aria-label="{{ 'general.horizontal_gallery.next' | t }}" aria-controls="Horizontal-Gallery-{{ section.id }}">
            <span class="svg-wrapper">{{- 'icon-caret.svg' | inline_asset_content -}}</span>
          </button>
        </div>
      </div>
    {%- elsif request.design_mode -%}
      <div class="premium-section-empty-state">
        <p>{{ 'general.horizontal_gallery.empty_state' | t }}</p>
      </div>
    {%- endif -%}
  </div>
</div>

<script src="{{ 'homepage.js' | asset_url }}" defer="defer"></script>

{% schema %}
{
  "name": "Horizontal gallery",
  "class": "section-horizontal-gallery-premium",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Gallery"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Layout rhythm",
      "info": "Controls the repeating pattern of large/small items along the scroll track.",
      "options": [
        { "value": "alternating", "label": "Alternating" },
        { "value": "uniform", "label": "Uniform (use each item's own size)" }
      ],
      "default": "uniform"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button label"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Button link"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Image",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "select",
          "id": "size",
          "label": "Size",
          "options": [
            { "value": "large", "label": "Large" },
            { "value": "small", "label": "Small" }
          ],
          "default": "large"
        },
        {
          "type": "text",
          "id": "caption",
          "label": "Caption"
        },
        {
          "type": "product",
          "id": "product",
          "label": "Link to product",
          "info": "Takes priority over the link below."
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link",
          "info": "Used when no product is selected above."
        }
      ]
    }
  ],
  "max_blocks": 16,
  "presets": [
    {
      "name": "Horizontal gallery",
      "blocks": [
        { "type": "item" },
        { "type": "item" },
        { "type": "item" },
        { "type": "item" }
      ]
    }
  ]
}
{% endschema %}
