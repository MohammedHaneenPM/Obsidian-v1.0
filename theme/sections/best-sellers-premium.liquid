{% comment %}
  Best Sellers (premium) - Milestone 4, Phase 1.

  Note on sort order: Liquid can't force an arbitrary sort on a collection
  independently of the collection's own configured sort order. This
  section reads settings.collection.products as-is, so for it to actually
  show best sellers, the merchant needs to set that collection's sort
  order to "Best selling" in Shopify Admin > Collections. A schema
  paragraph below reminds them of this.
{% endcomment %}

{{ 'component-card-premium.css' | asset_url | stylesheet_tag }}
{{ 'component-slider.css' | asset_url | stylesheet_tag }}
{{ 'component-price.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

{%- liquid
  assign is_carousel = false
  if section.settings.layout == 'carousel'
    assign is_carousel = true
  endif
-%}

<div class="color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding">
  <div class="page-width">
    {%- render 'section-header',
      eyebrow: section.settings.eyebrow,
      heading: section.settings.heading,
      description: section.settings.description,
      button_text: section.settings.button_text,
      button_url: section.settings.button_url | default: section.settings.collection.url,
      alignment: section.settings.heading_alignment,
      section_id: section.id
    -%}

    {%- if section.settings.collection != blank and section.settings.collection.products.size > 0 -%}
      {%- capture bestseller_items -%}
        {%- for product in section.settings.collection.products limit: section.settings.products_to_show -%}
          <li id="Slide-{{ section.id }}-{{ forloop.index }}" class="best-sellers-premium__item grid__item{% if is_carousel %} slider__slide{% endif %}">
            {%- render 'product-card-premium',
              card_product: product,
              media_aspect_ratio: section.settings.image_ratio,
              show_vendor: section.settings.show_vendor,
              show_rating: section.settings.show_rating,
              show_quick_add: section.settings.show_quick_add,
              show_wishlist: section.settings.show_wishlist,
              show_swatches: section.settings.show_swatches,
              new_badge_days: section.settings.new_badge_days,
              section_id: section.id
            -%}
          </li>
        {%- endfor -%}
      {%- endcapture -%}
      {%- render 'premium-grid',
        items: bestseller_items,
        is_carousel: is_carousel,
        columns_desktop: section.settings.columns_desktop,
        columns_mobile: section.settings.columns_mobile,
        total_count: section.settings.collection.products.size | at_most: section.settings.products_to_show,
        section_id: section.id,
        grid_class: 'best-sellers-premium__grid'
      -%}
    {%- elsif request.design_mode or section.settings.collection == blank -%}
      <p class="premium-section-empty-state">{{ 'general.best_sellers.no_collection' | t }}</p>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Best sellers (premium)",
  "class": "section-best-sellers-premium",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Best sellers"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description"
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "Header alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" }
      ],
      "default": "left"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button label",
      "default": "Shop all best sellers"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Button link",
      "info": "Leave blank to link to the collection below automatically."
    },
    {
      "type": "header",
      "content": "Collection"
    },
    {
      "type": "paragraph",
      "content": "For this section to actually show best sellers, set this collection's sort order to \"Best selling\" under Shopify Admin > Products > Collections > [collection] > Sort."
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "Products to show",
      "min": 2,
      "max": 24,
      "step": 1,
      "default": 8
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Layout",
      "options": [
        { "value": "grid", "label": "Grid" },
        { "value": "carousel", "label": "Carousel (horizontal scroll)" }
      ],
      "default": "carousel"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "Columns on desktop",
      "min": 2,
      "max": 5,
      "step": 1,
      "default": 4
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "label": "Columns on mobile",
      "options": [
        { "value": "1", "label": "1" },
        { "value": "2", "label": "2" }
      ],
      "default": "2"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "label": "Image ratio",
      "options": [
        { "value": "square", "label": "Square" },
        { "value": "portrait", "label": "Portrait" },
        { "value": "landscape", "label": "Landscape" }
      ],
      "default": "square"
    },
    {
      "type": "header",
      "content": "Card content"
    },
    {
      "type": "checkbox",
      "id": "show_vendor",
      "label": "Show vendor",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_rating",
      "label": "Show rating placeholder",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_quick_add",
      "label": "Show quick add",
      "info": "Currently links to the product page. Cart interactions are scoped to a later milestone.",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_wishlist",
      "label": "Show wishlist button",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_swatches",
      "label": "Show color swatches",
      "default": true
    },
    {
      "type": "header",
      "content": "t:sections.all.colors.label"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 48
    }
  ],
  "presets": [
    {
      "name": "Best sellers (premium)"
    }
  ]
}
{% endschema %}
