{% comment %}
  Before / After Slider (premium) - Milestone 4, Phase 2.
  Drag/touch handled via the Pointer Events API (unifies mouse, touch, and
  pen), plus a visually-hidden native range input for keyboard access.
  JS lives in homepage.js (initBeforeAfterSliders).
{% endcomment %}

{{ 'component-before-after-premium.css' | asset_url | stylesheet_tag }}
{{ 'component-card-premium.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding">
  <div class="page-width">
    {%- render 'section-header',
      eyebrow: section.settings.eyebrow,
      heading: section.settings.heading,
      description: section.settings.description,
      alignment: section.settings.heading_alignment,
      section_id: section.id
    -%}

    <div
      class="before-after-premium"
      data-before-after
      style="--ratio-percent: {{ 1.0 | divided_by: section.settings.image_ratio | times: 100 }}%; --ba-position: {{ section.settings.initial_position }}%;"
    >
      <div class="before-after-premium__frame">
        {%- if section.settings.after_image != blank -%}
          <img
            src="{{ section.settings.after_image | image_url: width: 1500 }}"
            srcset="
              {{ section.settings.after_image | image_url: width: 500 }} 500w,
              {{ section.settings.after_image | image_url: width: 900 }} 900w,
              {{ section.settings.after_image | image_url: width: 1500 }} 1500w
            "
            sizes="(min-width: 750px) 80vw, 100vw"
            alt="{{ section.settings.after_image.alt | default: section.settings.after_label | escape }}"
            class="before-after-premium__image before-after-premium__image--after"
            loading="lazy"
            width="{{ section.settings.after_image.width }}"
            height="{{ section.settings.after_image.height }}"
          >
        {%- else -%}
          {{ 'lifestyle-2' | placeholder_svg_tag: 'placeholder-svg before-after-premium__image before-after-premium__image--after' }}
        {%- endif -%}

        <div class="before-after-premium__clip" data-ba-clip>
          {%- if section.settings.before_image != blank -%}
            <img
              src="{{ section.settings.before_image | image_url: width: 1500 }}"
              srcset="
                {{ section.settings.before_image | image_url: width: 500 }} 500w,
                {{ section.settings.before_image | image_url: width: 900 }} 900w,
                {{ section.settings.before_image | image_url: width: 1500 }} 1500w
              "
              sizes="(min-width: 750px) 80vw, 100vw"
              alt="{{ section.settings.before_image.alt | default: section.settings.before_label | escape }}"
              class="before-after-premium__image before-after-premium__image--before"
              loading="lazy"
              width="{{ section.settings.before_image.width }}"
              height="{{ section.settings.before_image.height }}"
            >
          {%- else -%}
            {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg before-after-premium__image before-after-premium__image--before' }}
          {%- endif -%}
        </div>

        {%- if section.settings.before_label != blank -%}
          <span class="before-after-premium__label before-after-premium__label--before">{{ section.settings.before_label | escape }}</span>
        {%- endif -%}
        {%- if section.settings.after_label != blank -%}
          <span class="before-after-premium__label before-after-premium__label--after">{{ section.settings.after_label | escape }}</span>
        {%- endif -%}

        <div class="before-after-premium__handle" data-ba-handle aria-hidden="true">
          <span class="before-after-premium__handle-grip">
            <svg viewBox="0 0 10 14" width="10" height="14" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M1 0v14M5 0v14M9 0v14" stroke="currentColor" stroke-width="2"/>
            </svg>
          </span>
        </div>
      </div>

      <label class="visually-hidden" for="BeforeAfter-{{ section.id }}">
        {{ 'general.before_after.slider_label' | t }}
      </label>
      <input
        type="range"
        id="BeforeAfter-{{ section.id }}"
        class="before-after-premium__range visually-hidden"
        min="0"
        max="100"
        step="1"
        value="{{ section.settings.initial_position }}"
        data-ba-input
      >
    </div>
  </div>
</div>

<script src="{{ 'homepage.js' | asset_url }}" defer="defer"></script>

{% schema %}
{
  "name": "Before / after (Premium)",
  "class": "section-before-after-premium",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "See the difference"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description"
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "Header alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "header",
      "content": "Images"
    },
    {
      "type": "image_picker",
      "id": "before_image",
      "label": "Before image"
    },
    {
      "type": "text",
      "id": "before_label",
      "label": "Before label",
      "default": "Before"
    },
    {
      "type": "image_picker",
      "id": "after_image",
      "label": "After image"
    },
    {
      "type": "text",
      "id": "after_label",
      "label": "After label",
      "default": "After"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "label": "Image ratio",
      "options": [
        { "value": "0.75", "label": "Portrait" },
        { "value": "1", "label": "Square" },
        { "value": "1.5", "label": "Landscape" }
      ],
      "default": "1.5"
    },
    {
      "type": "range",
      "id": "initial_position",
      "label": "Starting position",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 50
    },
    {
      "type": "header",
      "content": "t:sections.all.colors.label"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 48
    }
  ],
  "presets": [
    {
      "name": "Before / after slider (premium)"
    }
  ]
}
{% endschema %}
