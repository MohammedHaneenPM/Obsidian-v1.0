{% comment %}
  Logo Cloud Premium - Milestone 4, Phase 3.

  A new, standalone "as seen in" / brand logo bar section. Supports grid,
  carousel (reuses the existing 'premium-grid' snippet / <slider-component>),
  and a marquee layout. The marquee is STRUCTURE ONLY, per the brief - the
  row of logos is duplicated in the DOM so it's ready for a continuous-loop
  animation, but no CSS animation/JS auto-scroll is added here (that's a
  Milestone 8 GSAP concern, same convention as the hero's animation hooks).
{% endcomment %}

{{ 'component-logo-cloud-premium.css' | asset_url | stylesheet_tag }}
{{ 'component-premium-shared.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="color-{{ section.settings.color_scheme }} gradient">
  <div class="logo-cloud-premium page-width section-{{ section.id }}-padding">
    {%- render 'section-header',
      heading: section.settings.heading,
      description: section.settings.description,
      alignment: 'center',
      section_id: section.id
    -%}

    {%- if section.blocks.size > 0 -%}
      {%- liquid
        assign wrapper_classes = 'logo-cloud-premium__wrapper'
        if section.settings.grayscale
          assign wrapper_classes = wrapper_classes | append: ' logo-cloud-premium__wrapper--grayscale'
        endif
        if section.settings.hover_color and section.settings.grayscale
          assign wrapper_classes = wrapper_classes | append: ' logo-cloud-premium__wrapper--hover-color'
        endif
      -%}

      {%- if section.settings.layout == 'marquee' -%}
        <div class="{{ wrapper_classes }} logo-cloud-premium__marquee" data-logo-marquee>
          {%- comment -%} Structure only: track is duplicated once for a future seamless loop. No animation is applied. {%- endcomment -%}
          <div class="logo-cloud-premium__marquee-track">
            {%- for i in (1..2) -%}
              <ul class="logo-cloud-premium__marquee-set list-unstyled" role="list" {% if i == 2 %}aria-hidden="true"{% endif %}>
                {%- for block in section.blocks -%}
                  <li class="logo-cloud-premium__item" {% if i == 1 %}{{ block.shopify_attributes }}{% endif %}>
                    {%- render 'logo-cloud-premium-logo', block: block -%}
                  </li>
                {%- endfor -%}
              </ul>
            {%- endfor -%}
          </div>
        </div>
      {%- else -%}
        {%- capture items -%}
          {%- for block in section.blocks -%}
            <li class="logo-cloud-premium__item grid__item" {{ block.shopify_attributes }}>
              {%- render 'logo-cloud-premium-logo', block: block -%}
            </li>
          {%- endfor -%}
        {%- endcapture -%}

        <div class="{{ wrapper_classes }}">
          {%- render 'premium-grid',
            items: items,
            is_carousel: section.settings.layout == 'carousel',
            columns_desktop: section.settings.columns_desktop,
            columns_mobile: '2',
            total_count: section.blocks.size,
            section_id: section.id,
            grid_class: 'logo-cloud-premium__grid'
          -%}
        </div>
      {%- endif -%}
    {%- else -%}
      <div class="logo-cloud-premium__empty-state premium-section-empty-state">
        <p>{{ 'general.logo_cloud_premium.no_logos' | t }}</p>
      </div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Logo cloud (premium)",
  "class": "section-logo-cloud-premium",
  "tag": "section",
  "settings": [
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "As seen in"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Layout",
      "options": [
        { "value": "grid", "label": "Grid" },
        { "value": "carousel", "label": "Carousel" },
        { "value": "marquee", "label": "Marquee" }
      ],
      "default": "grid"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "Columns on desktop",
      "min": 3,
      "max": 8,
      "step": 1,
      "default": 5
    },
    {
      "type": "checkbox",
      "id": "grayscale",
      "label": "Grayscale logos",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "hover_color",
      "label": "Show color on hover",
      "info": "Only applies when Grayscale logos is on.",
      "default": true
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "logo",
      "name": "Logo",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Logo image",
          "info": "Supports SVG or raster images."
        },
        {
          "type": "text",
          "id": "alt",
          "label": "Accessible description (alt text)"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "max_blocks": 24,
  "presets": [
    {
      "name": "Logo cloud (premium)",
      "blocks": [
        { "type": "logo" },
        { "type": "logo" },
        { "type": "logo" },
        { "type": "logo" },
        { "type": "logo" }
      ]
    }
  ]
}
{% endschema %}
