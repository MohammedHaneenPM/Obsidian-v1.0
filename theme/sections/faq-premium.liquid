{% comment %}
  FAQ Premium - Milestone 4, Phase 3.

  A new, standalone FAQ section supporting unlimited FAQ blocks, optional
  categories (a free-text field per block; matching categories are
  collected into filter pills), a live search field, and expand-all /
  collapse-all controls. Accordion markup reuses the theme's existing
  native <details>/<summary> + .accordion CSS component (same technique
  as sections/collapsible-content.liquid), so no new disclosure CSS
  pattern is introduced. Search/filter/expand-all behavior is new
  functionality, added to assets/homepage.js.
{% endcomment %}

{{ 'component-accordion.css' | asset_url | stylesheet_tag }}
{{ 'component-faq-premium.css' | asset_url | stylesheet_tag }}
{{ 'component-premium-shared.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

{%- liquid
  assign categories = ''
  for block in section.blocks
    if block.settings.category != blank and categories contains block.settings.category
      continue
    endif
    if block.settings.category != blank
      assign categories = categories | append: block.settings.category | append: '||'
    endif
  endfor
  assign category_list = categories | split: '||'
-%}

<div class="color-{{ section.settings.color_scheme }} gradient">
  <div class="faq-premium page-width section-{{ section.id }}-padding">
    {%- render 'section-header',
      heading: section.settings.heading,
      description: section.settings.description,
      alignment: 'center',
      section_id: section.id
    -%}

    {%- if section.blocks.size > 0 -%}
      <div class="faq-premium__controls" data-faq-premium="{{ section.id }}">
        {%- if section.settings.show_search -%}
          <div class="faq-premium__search field">
            <input
              type="search"
              class="field__input"
              id="FaqSearch-{{ section.id }}"
              data-faq-search
              placeholder="{{ 'general.faq_premium.search_placeholder' | t }}"
              autocomplete="off"
            >
            <label class="field__label" for="FaqSearch-{{ section.id }}">
              {{ 'general.faq_premium.search_placeholder' | t }}
            </label>
            <span class="svg-wrapper faq-premium__search-icon" aria-hidden="true">{{- 'icon-search.svg' | inline_asset_content -}}</span>
          </div>
        {%- endif -%}

        {%- if category_list.size > 1 -%}
          <div class="faq-premium__categories" role="group" aria-label="{{ 'general.faq_premium.categories_label' | t }}">
            <button type="button" class="faq-premium__category-pill is-active" data-faq-category="all">
              {{ 'general.faq_premium.all_categories' | t }}
            </button>
            {%- for category in category_list -%}
              <button type="button" class="faq-premium__category-pill" data-faq-category="{{ category | escape }}">
                {{ category | escape }}
              </button>
            {%- endfor -%}
          </div>
        {%- endif -%}

        {%- if section.settings.show_expand_collapse -%}
          <div class="faq-premium__expand-controls">
            <button type="button" class="link link--text" data-faq-expand-all>
              {{ 'general.faq_premium.expand_all' | t }}
            </button>
            <span aria-hidden="true">&middot;</span>
            <button type="button" class="link link--text" data-faq-collapse-all>
              {{ 'general.faq_premium.collapse_all' | t }}
            </button>
          </div>
        {%- endif -%}
      </div>

      <div class="faq-premium__list" data-faq-list>
        {%- for block in section.blocks -%}
          <div
            class="accordion faq-premium__item"
            data-faq-item
            data-faq-category="{{ block.settings.category | escape }}"
            data-faq-search-text="{{ block.settings.question | strip_html | append: ' ' | append: block.settings.answer | strip_html | escape }}"
            {{ block.shopify_attributes }}
          >
            <details id="FaqDetails-{{ block.id }}">
              <summary id="FaqSummary-{{ block.id }}">
                <h3 class="accordion__title h4">{{ block.settings.question | escape }}</h3>
                {{- 'icon-caret.svg' | inline_asset_content -}}
              </summary>
              <div
                class="accordion__content rte"
                id="FaqContent-{{ block.id }}"
                role="region"
                aria-labelledby="FaqSummary-{{ block.id }}"
              >
                {{ block.settings.answer }}
              </div>
            </details>
          </div>
        {%- endfor -%}
      </div>

      <p class="faq-premium__no-results" data-faq-no-results hidden>
        {{ 'general.faq_premium.no_results' | t }}
      </p>
    {%- else -%}
      <div class="faq-premium__empty-state premium-section-empty-state">
        <p>{{ 'general.faq_premium.no_faqs' | t }}</p>
      </div>
    {%- endif -%}
  </div>
</div>

<script src="{{ 'homepage.js' | asset_url }}" defer="defer"></script>

{% schema %}
{
  "name": "FAQ (premium)",
  "class": "section-faq-premium",
  "tag": "section",
  "settings": [
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Frequently asked questions"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description"
    },
    {
      "type": "checkbox",
      "id": "show_search",
      "label": "Show search field",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_expand_collapse",
      "label": "Show expand all / collapse all",
      "default": true
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 52
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 52
    }
  ],
  "blocks": [
    {
      "type": "faq",
      "name": "FAQ",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "How long does shipping take?"
        },
        {
          "type": "richtext",
          "id": "answer",
          "label": "Answer",
          "default": "<p>Orders ship within 1-2 business days and typically arrive within a week.</p>"
        },
        {
          "type": "text",
          "id": "category",
          "label": "Category",
          "info": "Optional. FAQs that share a category get a filter pill above the list."
        }
      ]
    }
  ],
  "max_blocks": 50,
  "presets": [
    {
      "name": "FAQ (premium)",
      "blocks": [
        { "type": "faq" },
        { "type": "faq" },
        { "type": "faq" }
      ]
    }
  ]
}
{% endschema %}
