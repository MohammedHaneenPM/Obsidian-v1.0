{% comment %}
  Product Recommendations (premium) - Milestone 5, Phase 2.
  A more flexible alternative to Dawn's native sections/related-products.liquid
  (untouched, still available): adds a manual fallback and a carousel
  option, plus lets the merchant pick related vs. complementary as the
  recommendation source. Shares its rendering logic with
  complementary-products-premium.liquid via product-recommendations-block.liquid.
{% endcomment %}

{{ 'component-card-premium.css' | asset_url | stylesheet_tag }}
{{ 'component-slider.css' | asset_url | stylesheet_tag }}
{{ 'component-price.css' | asset_url | stylesheet_tag }}
{{ 'component-product-recommendations-premium.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

{%- if product != blank -%}
  <div class="color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding">
    <div class="page-width">
      {%- render 'section-header',
        heading: section.settings.heading,
        description: section.settings.description,
        alignment: 'left',
        section_id: section.id
      -%}
      {%- render 'product-recommendations-block', section: section, intent: section.settings.recommendation_type -%}
    </div>
  </div>
{%- endif -%}

{% schema %}
{
  "name": "Product recommendations",
  "class": "section-product-recommendations-premium",
  "tag": "section",
  "max_blocks": 12,
  "settings": [
    {
      "type": "paragraph",
      "content": "Only displays on product pages."
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Recommended for you"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description"
    },
    {
      "type": "header",
      "content": "Recommendations"
    },
    {
      "type": "select",
      "id": "recommendation_type",
      "label": "Recommendation source",
      "options": [
        { "value": "related", "label": "Related products" },
        { "value": "complementary", "label": "Complementary products" }
      ],
      "default": "related",
      "info": "Both use Shopify's automatic recommendation engine (Search & Discovery where installed)."
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Layout",
      "options": [
        { "value": "grid", "label": "Grid" },
        { "value": "carousel", "label": "Carousel" }
      ],
      "default": "grid"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "Columns on desktop",
      "min": 2,
      "max": 5,
      "step": 1,
      "default": 4
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "label": "Columns on mobile",
      "options": [
        { "value": "1", "label": "1" },
        { "value": "2", "label": "2" }
      ],
      "default": "2"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "Products to show",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 4
    },
    {
      "type": "header",
      "content": "Manual fallback"
    },
    {
      "type": "paragraph",
      "content": "Used only when there are no automatic recommendations for this product."
    },
    {
      "type": "header",
      "content": "t:sections.all.colors.label"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Fallback product",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product recommendations"
    }
  ]
}
{% endschema %}
