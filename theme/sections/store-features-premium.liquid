{% comment %}
  Store Features - Milestone 4, Phase 3.

  A new, standalone trust-badge / icon-feature bar section (free shipping,
  secure checkout, easy returns, etc.). Distinct from snippets/icon-with-text
  (a Dawn "icon with text" block used inside other sections, max 3 items,
  untouched) - this is a full section with unlimited blocks, its own
  curated icon picker, an optional custom image upload per block, grid or
  carousel layout, and an optional link per feature.
{% endcomment %}

{{ 'component-store-features-premium.css' | asset_url | stylesheet_tag }}
{{ 'component-premium-shared.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="color-{{ section.settings.color_scheme }} gradient">
  <div class="store-features-premium page-width section-{{ section.id }}-padding">
    {%- render 'section-header',
      heading: section.settings.heading,
      description: section.settings.description,
      alignment: 'center',
      section_id: section.id
    -%}

    {%- if section.blocks.size > 0 -%}
      {%- capture items -%}
        {%- comment -%}theme-check-disable UnusedAssign{%- endcomment -%}
        {%- for block in section.blocks -%}
          <li class="store-features-premium__item grid__item" {{ block.shopify_attributes }}>
            {%- if block.settings.link != blank -%}<a href="{{ block.settings.link }}" class="store-features-premium__card store-features-premium__card--link">{%- else -%}<div class="store-features-premium__card">{%- endif -%}
              <span class="store-features-premium__icon" aria-hidden="true">
                {%- if block.settings.image != blank -%}
                  <img
                    src="{{ block.settings.image | image_url: width: 96 }}"
                    alt=""
                    width="48"
                    height="48"
                    loading="lazy"
                  >
                {%- elsif block.settings.icon != 'none' -%}
                  {{- block.settings.icon | prepend: 'icon-' | append: '.svg' | inline_asset_content -}}
                {%- endif -%}
              </span>
              {%- if block.settings.heading != blank -%}
                <h3 class="store-features-premium__heading h5">{{ block.settings.heading | escape }}</h3>
              {%- endif -%}
              {%- if block.settings.text != blank -%}
                <div class="store-features-premium__text rte">{{ block.settings.text }}</div>
              {%- endif -%}
            {%- if block.settings.link != blank -%}</a>{%- else -%}</div>{%- endif -%}
          </li>
        {%- endfor -%}
      {%- endcapture -%}

      {%- render 'premium-grid',
        items: items,
        is_carousel: section.settings.layout == 'carousel',
        columns_desktop: section.settings.columns_desktop,
        columns_mobile: '2',
        total_count: section.blocks.size,
        section_id: section.id,
        grid_class: 'store-features-premium__grid'
      -%}
    {%- else -%}
      <div class="store-features-premium__empty-state premium-section-empty-state">
        <p>{{ 'general.store_features_premium.no_features' | t }}</p>
      </div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Store features",
  "class": "section-store-features-premium",
  "tag": "section",
  "settings": [
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Layout",
      "options": [
        { "value": "grid", "label": "Grid" },
        { "value": "carousel", "label": "Carousel" }
      ],
      "default": "grid"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "Columns on desktop",
      "min": 3,
      "max": 6,
      "step": 1,
      "default": 4
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "none", "label": "None" },
            { "value": "truck", "label": "Truck (shipping)" },
            { "value": "lock", "label": "Lock (secure checkout)" },
            { "value": "return", "label": "Return arrow (returns)" },
            { "value": "stopwatch", "label": "Stopwatch (fast delivery)" },
            { "value": "checkmark", "label": "Checkmark (quality)" },
            { "value": "chat-bubble", "label": "Chat bubble (support)" },
            { "value": "heart", "label": "Heart (loved by customers)" },
            { "value": "recycle", "label": "Recycle (sustainability)" },
            { "value": "price-tag", "label": "Price tag (best price)" },
            { "value": "box", "label": "Box (packaging)" },
            { "value": "plane", "label": "Plane (worldwide shipping)" }
          ],
          "default": "truck"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Custom icon image",
          "info": "Optional. Overrides the icon selection above."
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Free shipping"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Text",
          "default": "<p>On all orders over $50</p>"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [
    {
      "name": "Store features",
      "blocks": [
        { "type": "feature" },
        { "type": "feature", "settings": { "icon": "lock", "heading": "Secure checkout", "text": "<p>SSL encrypted checkout</p>" } },
        { "type": "feature", "settings": { "icon": "return", "heading": "Easy returns", "text": "<p>30-day return policy</p>" } },
        { "type": "feature", "settings": { "icon": "chat-bubble", "heading": "24/7 support", "text": "<p>We're here to help</p>" } }
      ]
    }
  ]
}
{% endschema %}
