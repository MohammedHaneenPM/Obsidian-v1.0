{% comment %}
  Trust Badges (premium) - Milestone 5, Phase 2.
  Works on any template (not product-only) so it can also be placed in the
  product template's block list or as a standalone section elsewhere.
{% endcomment %}

{{ 'component-trust-badges-premium.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding">
  <div class="page-width">
    {%- render 'section-header',
      heading: section.settings.heading,
      description: section.settings.description,
      alignment: section.settings.heading_alignment,
      section_id: section.id
    -%}

    {%- if section.blocks.size > 0 -%}
      <ul class="trust-badges-premium trust-badges-premium--{{ section.settings.layout }}" role="list">
        {%- for block in section.blocks -%}
          <li class="trust-badges-premium__item" {{ block.shopify_attributes }}>
            {%- if block.settings.icon != blank -%}
              <span class="trust-badges-premium__icon">
                {{- block.settings.icon | image_url: width: 80 | image_tag: loading: 'lazy', width: 40, height: 40 -}}
              </span>
            {%- else -%}
              <span class="trust-badges-premium__icon trust-badges-premium__icon--placeholder" aria-hidden="true">
                {{- 'icon-checkmark.svg' | inline_asset_content -}}
              </span>
            {%- endif -%}
            <span class="trust-badges-premium__text">
              <span class="trust-badges-premium__title">{{ block.settings.title | escape }}</span>
              {%- if block.settings.subtext != blank -%}
                <span class="trust-badges-premium__subtext">{{ block.settings.subtext | escape }}</span>
              {%- endif -%}
            </span>
          </li>
        {%- endfor -%}
      </ul>
    {%- elsif request.design_mode -%}
      <p class="premium-section-empty-state">{{ 'general.onboarding.add_trust_badges' | t }}</p>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Trust badges",
  "class": "section-trust-badges-premium",
  "tag": "section",
  "max_blocks": 8,
  "settings": [
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Why shop with us"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description"
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "Header alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" }
      ],
      "default": "center"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Layout",
      "options": [
        { "value": "grid", "label": "Grid" },
        { "value": "inline", "label": "Inline row" },
        { "value": "stacked", "label": "Stacked list" }
      ],
      "default": "grid"
    },
    {
      "type": "header",
      "content": "t:sections.all.colors.label"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "badge",
      "name": "Badge",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon",
          "info": "Upload a custom icon. Falls back to a checkmark if left blank."
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Secure checkout"
        },
        {
          "type": "text",
          "id": "subtext",
          "label": "Subtext",
          "default": "SSL encrypted payments"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Trust badges",
      "blocks": [
        { "type": "badge" },
        { "type": "badge" },
        { "type": "badge" },
        { "type": "badge" }
      ]
    }
  ]
}
{% endschema %}
