{% comment %}
  Instagram / Social Gallery Premium - Milestone 4, Phase 3.

  A new, standalone social/UGC gallery section. Merchants upload images
  manually via blocks (no Instagram API integration, per the brief).
  Supports grid, a pure-CSS masonry layout (CSS multi-column, no JS
  packing library), and a carousel (reuses 'premium-grid').
{% endcomment %}

{{ 'component-social-gallery-premium.css' | asset_url | stylesheet_tag }}
{{ 'component-premium-shared.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="color-{{ section.settings.color_scheme }} gradient">
  <div class="social-gallery-premium page-width section-{{ section.id }}-padding">
    {%- render 'section-header',
      eyebrow: section.settings.eyebrow,
      heading: section.settings.heading,
      description: section.settings.description,
      button_text: section.settings.button_text,
      button_url: section.settings.button_url,
      alignment: 'center',
      section_id: section.id
    -%}

    {%- if section.blocks.size > 0 -%}
      {%- capture items -%}
        {%- for block in section.blocks -%}
          {%- liquid
            assign tile_aria_label = block.settings.caption
            if tile_aria_label == blank
              assign tile_aria_label = 'general.social_gallery_premium.view_post' | t
            endif
          -%}
          <li class="social-gallery-premium__item grid__item" {{ block.shopify_attributes }}>
            <div class="social-gallery-premium__card">
              {%- if block.settings.link != blank -%}
                <a href="{{ block.settings.link }}" class="social-gallery-premium__link" aria-label="{{ tile_aria_label | escape }}">
              {%- endif -%}
              <div class="social-gallery-premium__media media">
                {%- if block.settings.image != blank -%}
                  <img
                    srcset="
                      {{ block.settings.image | image_url: width: 375 }} 375w,
                      {{ block.settings.image | image_url: width: 550 }} 550w,
                      {{ block.settings.image | image_url: width: 750 }} 750w
                    "
                    src="{{ block.settings.image | image_url: width: 550 }}"
                    sizes="(min-width: 990px) 25vw, (min-width: 750px) 33vw, 50vw"
                    alt="{{ block.settings.alt_text | default: block.settings.image.alt | escape }}"
                    width="{{ block.settings.image.width }}"
                    height="{{ block.settings.image.height }}"
                    loading="lazy"
                  >
                {%- else -%}
                  {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
                {%- endif -%}
                {%- if block.settings.link != blank -%}
                  <span class="social-gallery-premium__icon" aria-hidden="true">{{- 'icon-instagram.svg' | inline_asset_content -}}</span>
                {%- endif -%}
              </div>
              {%- if block.settings.caption != blank -%}
                <p class="social-gallery-premium__caption">{{ block.settings.caption | escape }}</p>
              {%- endif -%}
              {%- if block.settings.link != blank -%}
                </a>
              {%- endif -%}
              {%- if block.settings.product != blank -%}
                <a href="{{ block.settings.product.url }}" class="social-gallery-premium__product-tag">
                  <span class="svg-wrapper">{{- 'icon-price-tag.svg' | inline_asset_content -}}</span>
                  {{- block.settings.product.title | escape -}}
                </a>
              {%- endif -%}
            </div>
          </li>
        {%- endfor -%}
      {%- endcapture -%}

      {%- if section.settings.layout == 'masonry' -%}
        <ul class="social-gallery-premium__grid social-gallery-premium__grid--masonry grid--{{ section.settings.columns_desktop }}-col-desktop grid--{{ section.settings.columns_mobile }}-col-tablet-down" role="list">
          {{- items -}}
        </ul>
      {%- else -%}
        {%- render 'premium-grid',
          items: items,
          is_carousel: section.settings.layout == 'carousel',
          columns_desktop: section.settings.columns_desktop,
          columns_mobile: section.settings.columns_mobile,
          total_count: section.blocks.size,
          section_id: section.id,
          grid_class: 'social-gallery-premium__grid'
        -%}
      {%- endif -%}
    {%- else -%}
      <div class="social-gallery-premium__empty-state premium-section-empty-state">
        <p>{{ 'general.social_gallery_premium.no_images' | t }}</p>
      </div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Social gallery (premium)",
  "class": "section-social-gallery-premium",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Follow along"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "@yourstore"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button label",
      "default": "Follow us"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Layout",
      "options": [
        { "value": "grid", "label": "Grid" },
        { "value": "masonry", "label": "Carousel" },
        { "value": "carousel", "label": "Marquee" }
      ],
      "default": "grid"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "Columns on desktop",
      "min": 3,
      "max": 6,
      "step": 1,
      "default": 4
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "label": "Columns on mobile",
      "options": [
        { "value": "1", "label": "1 column" },
        { "value": "2", "label": "2 columns" }
      ],
      "default": "2"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 52
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 52
    }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "Image",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "alt_text",
          "label": "Accessible description (alt text)"
        },
        {
          "type": "text",
          "id": "caption",
          "label": "Caption"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link",
          "info": "Links the image, e.g. to the original social post."
        },
        {
          "type": "product",
          "id": "product",
          "label": "Product reference"
        }
      ]
    }
  ],
  "max_blocks": 24,
  "presets": [
    {
      "name": "Social gallery (premium)",
      "blocks": [
        { "type": "image" },
        { "type": "image" },
        { "type": "image" },
        { "type": "image" }
      ]
    }
  ]
}
{% endschema %}
