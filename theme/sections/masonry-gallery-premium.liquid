{% comment %}
  Masonry Gallery - Milestone 4, Phase 4.

  Pinterest-style masonry grid using CSS columns (native aspect-ratio-driven
  masonry, no JS layout library). Each block can be an image or a
  click-to-play video (reusing the theme's existing <deferred-media>
  element, same as sections/split-banner-premium.liquid), optionally
  linked to a product, with a caption.
{% endcomment %}

{{ 'component-masonry-gallery-premium.css' | asset_url | stylesheet_tag }}
{{ 'component-premium-shared.css' | asset_url | stylesheet_tag }}
{{ 'component-deferred-media.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .section-{{ section.id }}-gap {
    --masonry-gap: {{ section.settings.grid_spacing }}px;
  }
{%- endstyle -%}

<div class="color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding">
  <div class="page-width">
    {%- render 'section-header',
      eyebrow: section.settings.eyebrow,
      heading: section.settings.heading,
      description: section.settings.description,
      alignment: section.settings.heading_alignment,
      section_id: section.id
    -%}

    {%- if section.blocks.size > 0 -%}
      <div class="masonry-gallery-premium section-{{ section.id }}-gap">
        {%- for block in section.blocks -%}
          {%- liquid
            assign item_product = block.settings.product
            assign item_url = block.settings.link
            if item_product != blank
              assign item_url = item_product.url
            endif
            assign media_description = block.settings.caption | default: 'Video'
          -%}
          <div class="masonry-gallery-premium__item" {{ block.shopify_attributes }}>
            <div class="masonry-gallery-premium__media">
              {%- if block.settings.media_type == 'video' and block.settings.video != blank -%}
                <deferred-media class="masonry-gallery-premium__deferred-media deferred-media" data-media-id="{{ block.settings.video.id }}">
                  <button
                    id="Deferred-Poster-Masonry-{{ block.id }}"
                    class="masonry-gallery-premium__poster media deferred-media__poster"
                    type="button"
                    aria-label="{{ 'sections.video.load_video' | t: description: media_description }}"
                  >
                    {%- if block.settings.image != blank -%}
                      <img
                        src="{{ block.settings.image | image_url: width: 800 }}"
                        alt=""
                        width="{{ block.settings.image.width }}"
                        height="{{ block.settings.image.height }}"
                        loading="lazy"
                      >
                    {%- endif -%}
                    <span class="deferred-media__poster-button motion-reduce">
                      <span class="svg-wrapper">{{- 'icon-play.svg' | inline_asset_content -}}</span>
                    </span>
                  </button>
                  <template>
                    {{ block.settings.video | video_tag: image_size: '800x', autoplay: true, loop: true, controls: true, muted: false }}
                  </template>
                </deferred-media>
              {%- elsif block.settings.image != blank -%}
                {%- if item_url != blank -%}<a href="{{ item_url }}" class="masonry-gallery-premium__link">{%- endif -%}
                  <img
                    src="{{ block.settings.image | image_url: width: 800 }}"
                    srcset="
                      {{ block.settings.image | image_url: width: 400 }} 400w,
                      {{ block.settings.image | image_url: width: 600 }} 600w,
                      {{ block.settings.image | image_url: width: 800 }} 800w
                    "
                    sizes="(min-width: 990px) 30vw, (min-width: 750px) 45vw, 90vw"
                    alt="{{ block.settings.image.alt | escape }}"
                    width="{{ block.settings.image.width }}"
                    height="{{ block.settings.image.height }}"
                    loading="lazy"
                  >
                {%- if item_url != blank -%}</a>{%- endif -%}
              {%- else -%}
                {{ 'lifestyle-2' | placeholder_svg_tag: 'placeholder-svg' }}
              {%- endif -%}
            </div>

            {%- if block.settings.caption != blank or item_product != blank -%}
              <div class="masonry-gallery-premium__caption-row">
                {%- if block.settings.caption != blank -%}
                  <p class="masonry-gallery-premium__caption">{{ block.settings.caption | escape }}</p>
                {%- endif -%}
                {%- if item_product != blank -%}
                  <a href="{{ item_product.url }}" class="masonry-gallery-premium__product-link link link--text">
                    {{- item_product.title -}}
                  </a>
                {%- endif -%}
              </div>
            {%- endif -%}
          </div>
        {%- endfor -%}
      </div>
    {%- elsif request.design_mode -%}
      <div class="premium-section-empty-state">
        <p>{{ 'general.masonry_gallery.empty_state' | t }}</p>
      </div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Masonry gallery",
  "class": "section-masonry-gallery-premium",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Gallery"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description"
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "Header alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" }
      ],
      "default": "left"
    },
    {
      "type": "range",
      "id": "grid_spacing",
      "label": "Grid spacing",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 16
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Media item",
      "settings": [
        {
          "type": "select",
          "id": "media_type",
          "label": "Media type",
          "options": [
            { "value": "image", "label": "Image" },
            { "value": "video", "label": "Video" }
          ],
          "default": "image"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image",
          "info": "Also used as the video poster when media type is \"Video\"."
        },
        {
          "type": "video",
          "id": "video",
          "label": "Video",
          "info": "Used when media type is \"Video\"."
        },
        {
          "type": "text",
          "id": "caption",
          "label": "Caption"
        },
        {
          "type": "product",
          "id": "product",
          "label": "Link to product"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link",
          "info": "Used when no product is selected above. Ignored for videos."
        }
      ]
    }
  ],
  "max_blocks": 20,
  "presets": [
    {
      "name": "Masonry gallery",
      "blocks": [
        { "type": "item" },
        { "type": "item" },
        { "type": "item" },
        { "type": "item" },
        { "type": "item" }
      ]
    }
  ]
}
{% endschema %}
