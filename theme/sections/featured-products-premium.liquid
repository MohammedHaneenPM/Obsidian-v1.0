{% comment %}
  Featured Products (premium) - Milestone 4, Phase 1.
  Supports manual product picks or pulling from a collection. Grid or
  carousel layout; carousel reuses the theme's existing <slider-component>.
{% endcomment %}

{{ 'component-card-premium.css' | asset_url | stylesheet_tag }}
{{ 'component-slider.css' | asset_url | stylesheet_tag }}
{{ 'component-price.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

{%- liquid
  assign is_carousel = false
  if section.settings.layout == 'carousel'
    assign is_carousel = true
  endif

  assign products = section.blocks
  assign use_collection = false
  if section.settings.product_source == 'collection' and section.settings.collection != blank
    assign use_collection = true
  endif
-%}

<div class="color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding">
  <div class="page-width">
    {%- render 'section-header',
      eyebrow: section.settings.eyebrow,
      heading: section.settings.heading,
      description: section.settings.description,
      button_text: section.settings.button_text,
      button_url: section.settings.button_url,
      alignment: section.settings.heading_alignment,
      section_id: section.id
    -%}

    {%- liquid
      assign has_items = false
      if use_collection and section.settings.collection.products.size > 0
        assign has_items = true
      elsif use_collection == false and section.blocks.size > 0
        assign has_items = true
      endif
    -%}
    {%- if has_items -%}
      {%- capture product_items -%}
        {%- if use_collection -%}
          {%- for product in section.settings.collection.products limit: section.settings.products_to_show -%}
            <li id="Slide-{{ section.id }}-{{ forloop.index }}" class="featured-products-premium__item grid__item{% if is_carousel %} slider__slide{% endif %}">
              {%- render 'product-card-premium',
                card_product: product,
                media_aspect_ratio: section.settings.image_ratio,
                show_vendor: section.settings.show_vendor,
                show_rating: section.settings.show_rating,
                show_quick_add: section.settings.show_quick_add,
                show_wishlist: section.settings.show_wishlist,
                show_swatches: section.settings.show_swatches,
                new_badge_days: section.settings.new_badge_days,
                section_id: section.id
              -%}
            </li>
          {%- endfor -%}
        {%- else -%}
          {%- for block in section.blocks -%}
            <li
              id="Slide-{{ section.id }}-{{ forloop.index }}"
              class="featured-products-premium__item grid__item{% if is_carousel %} slider__slide{% endif %}"
              {{ block.shopify_attributes }}
            >
              {%- render 'product-card-premium',
                card_product: block.settings.product,
                media_aspect_ratio: section.settings.image_ratio,
                show_vendor: section.settings.show_vendor,
                show_rating: section.settings.show_rating,
                show_quick_add: section.settings.show_quick_add,
                show_wishlist: section.settings.show_wishlist,
                show_swatches: section.settings.show_swatches,
                new_badge_days: section.settings.new_badge_days,
                section_id: section.id
              -%}
            </li>
          {%- endfor -%}
        {%- endif -%}
      {%- endcapture -%}
      {%- if use_collection -%}
        {%- assign product_total_count = section.settings.collection.products.size | at_most: section.settings.products_to_show -%}
      {%- else -%}
        {%- assign product_total_count = section.blocks.size -%}
      {%- endif -%}
      {%- render 'premium-grid',
        items: product_items,
        is_carousel: is_carousel,
        columns_desktop: section.settings.columns_desktop,
        columns_mobile: section.settings.columns_mobile,
        total_count: product_total_count,
        section_id: section.id,
        grid_class: 'featured-products-premium__grid'
      -%}
    {%- elsif request.design_mode -%}
      <div class="premium-section-empty-state">
        <p>
          {%- if use_collection -%}
            {{ 'general.onboarding.empty_collection' | t }}
          {%- else -%}
            {{ 'general.onboarding.add_products' | t }}
          {%- endif -%}
        </p>
      </div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Featured prods (Premium)",
  "class": "section-featured-products-premium",
  "tag": "section",
  "max_blocks": 25,
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Featured products"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description"
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "Header alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" }
      ],
      "default": "left"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button label"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "Products"
    },
    {
      "type": "select",
      "id": "product_source",
      "label": "Product source",
      "options": [
        { "value": "manual", "label": "Manual selection (blocks below)" },
        { "value": "collection", "label": "From a collection" }
      ],
      "default": "manual"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection",
      "info": "Only used when product source is set to \"From a collection\"."
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "Products to show",
      "min": 2,
      "max": 24,
      "step": 1,
      "default": 8,
      "info": "Only used when product source is set to \"From a collection\"."
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Layout",
      "options": [
        { "value": "grid", "label": "Grid" },
        { "value": "carousel", "label": "Carousel (horizontal scroll)" }
      ],
      "default": "grid"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "Columns on desktop",
      "min": 2,
      "max": 5,
      "step": 1,
      "default": 4
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "label": "Columns on mobile",
      "options": [
        { "value": "1", "label": "1" },
        { "value": "2", "label": "2" }
      ],
      "default": "2"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "label": "Image ratio",
      "options": [
        { "value": "square", "label": "Square" },
        { "value": "portrait", "label": "Portrait" },
        { "value": "landscape", "label": "Landscape" }
      ],
      "default": "square"
    },
    {
      "type": "header",
      "content": "Card content"
    },
    {
      "type": "checkbox",
      "id": "show_vendor",
      "label": "Show vendor",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_rating",
      "label": "Show rating placeholder",
      "info": "Displays outline stars. Connect a reviews app later to show real ratings.",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_quick_add",
      "label": "Show quick add",
      "info": "Currently links to the product page. Cart interactions are scoped to a later milestone.",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_wishlist",
      "label": "Show wishlist button",
      "info": "Visual placeholder, ready for a future wishlist integration.",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_swatches",
      "label": "Show color swatches",
      "default": true
    },
    {
      "type": "range",
      "id": "new_badge_days",
      "label": "\"New\" badge cutoff",
      "min": 0,
      "max": 90,
      "step": 5,
      "unit": "day",
      "default": 30,
      "info": "Products published within this many days show a \"New\" badge."
    },
    {
      "type": "header",
      "content": "t:sections.all.colors.label"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 48
    }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Product",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Featured products (premium)",
      "blocks": [
        { "type": "product" },
        { "type": "product" },
        { "type": "product" },
        { "type": "product" }
      ]
    }
  ]
}
{% endschema %}
