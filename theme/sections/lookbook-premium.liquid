{% comment %}
  Lookbook (premium) - Milestone 4, Phase 2.
  Interactive hotspots positioned on an image, each linked to a product.
  Click/tap a hotspot to reveal a small product card. Works the same way
  on desktop, tablet, and mobile (tap/click), with responsive sizing.
{% endcomment %}

{{ 'component-lookbook-premium.css' | asset_url | stylesheet_tag }}
{{ 'component-card-premium.css' | asset_url | stylesheet_tag }}
{{ 'component-price.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding">
  <div class="page-width">
    {%- render 'section-header',
      eyebrow: section.settings.eyebrow,
      heading: section.settings.heading,
      description: section.settings.description,
      alignment: section.settings.heading_alignment,
      section_id: section.id
    -%}

    <div
      class="lookbook-premium__image-wrapper"
      style="--ratio-percent: {{ 1 | divided_by: section.settings.image_ratio | times: 100 }}%;"
    >
      {%- if section.settings.image != blank -%}
        <img
          srcset="
            {{ section.settings.image | image_url: width: 500 }} 500w,
            {{ section.settings.image | image_url: width: 800 }} 800w,
            {{ section.settings.image | image_url: width: 1200 }} 1200w,
            {{ section.settings.image | image_url: width: 1600 }} 1600w,
            {{ section.settings.image | image_url: width: 2000 }} 2000w
          "
          src="{{ section.settings.image | image_url: width: 1200 }}"
          sizes="(min-width: 750px) 80vw, 100vw"
          alt="{{ section.settings.image.alt | escape }}"
          class="lookbook-premium__image"
          loading="lazy"
          width="{{ section.settings.image.width }}"
          height="{{ section.settings.image.height }}"
        >
      {%- else -%}
        {{ 'lifestyle-apparel-1' | placeholder_svg_tag: 'placeholder-svg lookbook-premium__image' }}
      {%- endif -%}

      {%- for block in section.blocks -%}
        {%- if block.type == 'hotspot' and block.settings.product != blank -%}
          {%- render 'hotspot-popover',
            product: block.settings.product,
            position_x: block.settings.position_x,
            position_y: block.settings.position_y,
            section_id: section.id,
            shopify_attributes: block.shopify_attributes
          -%}
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</div>

<script src="{{ 'homepage.js' | asset_url }}" defer="defer"></script>

{% schema %}
{
  "name": "Lookbook (premium)",
  "class": "section-lookbook-premium",
  "tag": "section",
  "max_blocks": 10,
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Shop the look"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description"
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "Header alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" }
      ],
      "default": "left"
    },
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image",
      "info": "Add hotspot blocks below, then position each one over the matching product in this image."
    },
    {
      "type": "select",
      "id": "image_ratio",
      "label": "Image ratio",
      "options": [
        { "value": "0.75", "label": "Portrait" },
        { "value": "1", "label": "Square" },
        { "value": "1.5", "label": "Landscape" }
      ],
      "default": "0.75"
    },
    {
      "type": "header",
      "content": "t:sections.all.colors.label"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 48
    }
  ],
  "blocks": [
    {
      "type": "hotspot",
      "name": "Product hotspot",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        },
        {
          "type": "range",
          "id": "position_x",
          "label": "Horizontal position",
          "min": 0,
          "max": 100,
          "step": 1,
          "unit": "%",
          "default": 50
        },
        {
          "type": "range",
          "id": "position_y",
          "label": "Vertical position",
          "min": 0,
          "max": 100,
          "step": 1,
          "unit": "%",
          "default": 50
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Lookbook (premium)",
      "blocks": [
        { "type": "hotspot" },
        { "type": "hotspot" }
      ]
    }
  ]
}
{% endschema %}
