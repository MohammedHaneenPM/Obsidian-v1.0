{% comment %}
  Premium Image With Text - Milestone 4, Phase 2.
  Distinct from sections/image-with-text.liquid (untouched, still available).
{% endcomment %}

{{ 'component-image-with-text-premium.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

{%- liquid
  assign is_overlay = false
  if section.settings.layout == 'overlay'
    assign is_overlay = true
  endif
-%}

<div class="color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding">
  <div class="{% unless is_overlay %}page-width{% endunless %}">
    <div
      class="
        image-with-text-premium
        image-with-text-premium--{{ section.settings.layout }}
        image-with-text-premium--image-{{ section.settings.image_position }}
        {% if section.settings.show_decorative_border %} image-with-text-premium--bordered{% endif %}
      "
    >
      <div class="image-with-text-premium__media">
        {%- if section.settings.image != blank -%}
          <img
            srcset="
              {{ section.settings.image | image_url: width: 500 }} 500w,
              {{ section.settings.image | image_url: width: 800 }} 800w,
              {{ section.settings.image | image_url: width: 1200 }} 1200w,
              {{ section.settings.image | image_url: width: 1600 }} 1600w
            "
            src="{{ section.settings.image | image_url: width: 1200 }}"
            sizes="(min-width: 750px) 50vw, 100vw"
            alt="{{ section.settings.image.alt | escape }}"
            class="image-with-text-premium__image"
            loading="lazy"
            width="{{ section.settings.image.width }}"
            height="{{ section.settings.image.height }}"
          >
        {%- else -%}
          {{ 'lifestyle-apparel-2' | placeholder_svg_tag: 'placeholder-svg image-with-text-premium__image' }}
        {%- endif -%}
        {%- if section.settings.show_decorative_shape -%}
          <span class="image-with-text-premium__decorative-shape" aria-hidden="true"></span>
        {%- endif -%}
      </div>

      <div class="image-with-text-premium__content-wrapper">
        <div class="image-with-text-premium__content color-{{ section.settings.content_color_scheme }} gradient">
          {%- render 'section-header',
            eyebrow: section.settings.eyebrow,
            heading: section.settings.heading,
            description: section.settings.body,
            button_text: section.settings.button_text,
            button_url: section.settings.button_url,
            button_style: section.settings.button_style,
            alignment: 'left',
            section_id: section.id
          -%}
        </div>
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Image with text (premium)",
  "class": "section-image-with-text-premium",
  "tag": "section",
  "settings": [
    {
      "type": "select",
      "id": "layout",
      "label": "Layout",
      "options": [
        { "value": "split", "label": "Split (side by side)" },
        { "value": "overlay", "label": "Overlay (text on image)" }
      ],
      "default": "split"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Image position",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "Image with text"
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "Body text",
      "default": "<p>Pair text with an image to focus on the product or collection you'd like to feature.</p>"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button label"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Button link"
    },
    {
      "type": "select",
      "id": "button_style",
      "label": "Button style",
      "options": [
        { "value": "primary", "label": "Primary" },
        { "value": "secondary", "label": "Secondary" },
        { "value": "link", "label": "Text link" }
      ],
      "default": "link"
    },
    {
      "type": "header",
      "content": "Decorative options"
    },
    {
      "type": "checkbox",
      "id": "show_decorative_shape",
      "label": "Show decorative accent shape",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_decorative_border",
      "label": "Show border around image",
      "default": false
    },
    {
      "type": "header",
      "content": "t:sections.all.colors.label"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Section color scheme",
      "default": "scheme-1"
    },
    {
      "type": "color_scheme",
      "id": "content_color_scheme",
      "label": "Content panel color scheme",
      "info": "Only visible as a distinct panel in the overlay layout.",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 48
    }
  ],
  "presets": [
    {
      "name": "Image with text (premium)"
    }
  ]
}
{% endschema %}
