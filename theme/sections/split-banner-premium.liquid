{% comment %}
  Split Banner (premium) - Milestone 4, Phase 2.
  Two independent promotional panels, each with its own image/video, CTA,
  link, and color scheme. Implemented as blocks (max 2) so merchants can
  configure each side independently from the Theme Editor.
{% endcomment %}

{{ 'component-split-banner-premium.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="section-{{ section.id }}-padding">
  <div class="{% unless section.settings.full_bleed %}page-width{% endunless %}">
    <div class="split-banner-premium split-banner-premium--{{ section.settings.height }}">
      {%- for block in section.blocks -%}
        {%- liquid
          assign video_source = block.settings.video.sources | last
        -%}
        <div class="split-banner-premium__panel color-{{ block.settings.color_scheme }} gradient" {{ block.shopify_attributes }}>
          <div class="split-banner-premium__media">
            {%- if video_source != blank -%}
              <video
                class="split-banner-premium__video"
                autoplay
                muted
                loop
                playsinline
                preload="none"
                {% if block.settings.image != blank %}
                  poster="{{ block.settings.image | image_url: width: 1000 }}"
                {% endif %}
              >
                <source src="{{ video_source.url }}" type="{{ video_source.mime_type }}">
              </video>
            {%- elsif block.settings.image != blank -%}
              <img
                srcset="
                  {{ block.settings.image | image_url: width: 500 }} 500w,
                  {{ block.settings.image | image_url: width: 800 }} 800w,
                  {{ block.settings.image | image_url: width: 1200 }} 1200w,
                  {{ block.settings.image | image_url: width: 1600 }} 1600w
                "
                src="{{ block.settings.image | image_url: width: 1200 }}"
                sizes="(min-width: 750px) 50vw, 100vw"
                alt="{{ block.settings.image.alt | escape }}"
                class="split-banner-premium__image"
                loading="lazy"
                width="{{ block.settings.image.width }}"
                height="{{ block.settings.image.height }}"
              >
            {%- else -%}
              {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg split-banner-premium__image' }}
            {%- endif -%}
            <div
              class="split-banner-premium__overlay"
              style="--split-banner-overlay-opacity: {{ block.settings.overlay_opacity | divided_by: 100.0 }};"
              aria-hidden="true"
            ></div>
          </div>

          <div class="split-banner-premium__content">
            {%- if block.settings.heading != blank -%}
              <h2 class="split-banner-premium__heading h1 inline-richtext">{{ block.settings.heading }}</h2>
            {%- endif -%}
            {%- if block.settings.subheading != blank -%}
              <div class="split-banner-premium__subheading rte">{{ block.settings.subheading }}</div>
            {%- endif -%}
            {%- if block.settings.button_text != blank -%}
              {%- render 'button', text: block.settings.button_text, url: block.settings.button_url, style: block.settings.button_style -%}
            {%- endif -%}
          </div>

          {%- if block.settings.button_url != blank -%}
            <a
              href="{{ block.settings.button_url }}"
              class="split-banner-premium__full-link"
              aria-hidden="true"
              tabindex="-1"
            ></a>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Split banner (premium)",
  "class": "section-split-banner-premium",
  "tag": "section",
  "max_blocks": 2,
  "settings": [
    {
      "type": "select",
      "id": "height",
      "label": "Height",
      "options": [
        { "value": "small", "label": "Small" },
        { "value": "medium", "label": "Medium" },
        { "value": "large", "label": "Large" }
      ],
      "default": "medium"
    },
    {
      "type": "checkbox",
      "id": "full_bleed",
      "label": "Full width (edge to edge)",
      "default": true
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 0
    }
  ],
  "blocks": [
    {
      "type": "panel",
      "name": "Panel",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "video",
          "id": "video",
          "label": "Video",
          "info": "Optional. Overrides the image when set."
        },
        {
          "type": "range",
          "id": "overlay_opacity",
          "label": "Overlay opacity",
          "min": 0,
          "max": 80,
          "step": 5,
          "unit": "%",
          "default": 30
        },
        {
          "type": "inline_richtext",
          "id": "heading",
          "label": "Heading",
          "default": "Shop the edit"
        },
        {
          "type": "richtext",
          "id": "subheading",
          "label": "Subheading"
        },
        {
          "type": "text",
          "id": "button_text",
          "label": "Button label",
          "default": "Shop now"
        },
        {
          "type": "url",
          "id": "button_url",
          "label": "Button link",
          "info": "Also makes the whole panel clickable."
        },
        {
          "type": "select",
          "id": "button_style",
          "label": "Button style",
          "options": [
            { "value": "primary", "label": "Primary" },
            { "value": "secondary", "label": "Secondary" },
            { "value": "link", "label": "Text link" }
          ],
          "default": "secondary"
        },
        {
          "type": "color_scheme",
          "id": "color_scheme",
          "label": "Color scheme",
          "default": "scheme-1"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Split banner (premium)",
      "blocks": [
        { "type": "panel" },
        { "type": "panel" }
      ]
    }
  ]
}
{% endschema %}
